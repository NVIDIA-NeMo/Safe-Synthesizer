FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git curl build-essential make && \
    rm -rf /var/lib/apt/lists/*

# Install mise
RUN curl https://mise.run | sh
ENV PATH="/root/.local/bin:${PATH}"

# Keep venv outside /workspace so bind mounts don't shadow it
ENV UV_PROJECT_ENVIRONMENT=/opt/venv

WORKDIR /workspace

# Install CLI tools via mise (cached until mise.toml changes)
COPY mise.toml .
RUN mise install

# Install Python dependencies (cached until pyproject.toml, uv.lock, or src/ or tests/ change)
COPY Makefile .
COPY pyproject.toml .
COPY tools/ tools/
COPY ruff.toml .
COPY pytest.ini .
COPY README.md .
COPY uv.lock .
COPY src/ src/
COPY tests/ tests/
RUN make bootstrap-nss cpu


RUN git config --global --add safe.directory /workspace
