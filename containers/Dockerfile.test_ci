FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git curl build-essential make && \
    rm -rf /var/lib/apt/lists/*

# Keep venv outside /workspace so bind mounts don't shadow it
ENV UV_PROJECT_ENVIRONMENT=/opt/venv

WORKDIR /workspace

# Install CLI tools including uv (cached until tools/ or Makefile change)
COPY Makefile .
COPY tools/ tools/
COPY pyproject.toml .
RUN REPO_ROOT=/workspace make bootstrap-tools-ci

# bootstrap-tools-ci installs tools to ~/.local/bin
ENV PATH="/root/.local/bin:${PATH}"

# Install Python dependencies (cached until pyproject.toml, uv.lock, or src/ or tests/ change)
COPY ruff.toml .
COPY pytest.ini .
COPY README.md .
COPY uv.lock .
COPY src/ src/
COPY tests/ tests/
RUN make bootstrap-nss cpu


RUN git config --global --add safe.directory /workspace
