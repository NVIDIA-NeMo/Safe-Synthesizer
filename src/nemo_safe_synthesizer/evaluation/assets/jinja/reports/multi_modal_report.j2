<!DOCTYPE html>
<html lang="en">

<head>
    <title>NeMo Safe Synthesizer Evaluation Report</title>
    <link href='https://fonts.googleapis.com/css?family=Inter' rel='stylesheet'>
    <style>
        {% include "css/multi_modal_report.css" %}
    </style>
    <script src="https://cdn.plot.ly/plotly-2.35.3.min.js" charset="utf-8"></script>
</head>

<body>
    <div class="header-class">
        <div class="report-header fixed-div">
            <div>
                NVIDIA
            </div>
            <div class="report-title">
                Synthetic Quality & Privacy Report
            </div>
            <div></div>
        </div>
        <hr class="divider">
    </div>
    <div id="navbar">
        <nav id="fixed-nav">
            <a href="#overview" class="level-1">Overview</a>

            {% if ctx.with_synthesizer %}
                <a href="#overview-score" class="level-2">Score</a>
            {% endif %}

            <a href="#dataset-statistics" class="level-2">Dataset Statistics</a>

            {% if ctx.with_synthesizer %}
                <a href="#synthetic-quality" class="level-1">Synthetic Quality</a>
                <a href="#synthetic-quality-score" class="level-2">Score</a>
            {% endif %}

            {% if ctx.get('column_distribution_stability', {}).get('evaluation_fields') %}
                <a href="#reference-columns" class="level-2">Reference Columns</a>
            {% endif %}

            {% if ctx.with_synthesizer %}
                {% if ctx.get('column_correlation_stability', {}).get('figure') %}
                <a href="#correlation-stability" class="level-2">Correlation Stability</a>
                {% endif %}
                {% if ctx.get('deep_structure_stability', {}).get('figure') %}
                <a href="#structure-stability" class="level-2">Structure Stability</a>
                {% endif %}
                {% if ctx.get('column_distribution_stability', {}).get('figures') %}
                <a href="#distribution-stability" class="level-2">Distribution Stability</a>
                {% endif %}
                {% if ctx.get('text_semantic_similarity', {}).get('figures') %}
                <a href="#semantic-similarity" class="level-2">Semantic Similarity</a>
                {% endif %}
                {% if ctx.get('text_structure_similarity', {}).get('figures') %}
                <a href="#structure-similarity" class="level-2">Structure Similarity</a>
                {% endif %}
            {% endif %}
            {% if (ctx.with_data_privacy) or (ctx.pii_replay and ctx.pii_replay.pii_replay_data) %}
                <a href="#data-privacy" class="level-1">Data Privacy</a>
                {% if ctx.with_data_privacy %}
                <a href="#data-privacy-score" class="level-2">Score</a>
                {% endif %}
                {% if ctx.pii_replay and ctx.pii_replay.pii_replay_data %}
                <a href="#pii-replay" class="level-2">PII Replay</a>
                {% endif %}
                {% if ctx.get('membership_inference_protection', {}).get('figure') %}
                <a href="#mia" class="level-2">Membership Inference Protection</a>
                {% endif %}
                {% if ctx.get('attribute_inference_protection', {}).get('figure') %}
                <a href="#aia" class="level-2">Attribute Inference Protection</a>
                {% endif %}
            {% endif %}

            {% if ctx.with_time_series %}
                <a href="#time-series" class="level-1">Time Series</a>
                {% if ctx.get('time_series_similarity_score') %}
                    <a href="#ts-score" class="level-2">Score</a>
                {% endif %}
                {% if ctx.get('autocorrelation_similarity') %}
                    <a href="#acf-similarity" class="level-2">Autocorrelation</a>
                {% endif %}
                {% if ctx.get('drift_similarity') %}
                    <a href="#drift-similarity" class="level-2">Drift</a>
                {% endif %}
                {% if ctx.get('hurst_similarity') %}
                    <a href="#hurst-similarity" class="level-2">Hurst Exponent</a>
                {% endif %}
                {% if ctx.get('dtw_similarity') %}
                    <a href="#dtw-similarity" class="level-2">DTW</a>
                {% endif %}
                {% if ctx.get('rolling_stats_similarity') %}
                    <a href="#rolling-stats-similarity" class="level-2">Rolling Stats</a>
                {% endif %}
                {% if ctx.get('spectral_similarity') %}
                    <a href="#spectral-similarity" class="level-2">Spectral</a>
                {% endif %}
                {% if ctx.get('adf_stationarity') %}
                    <a href="#adf-stationarity" class="level-2">ADF Stationarity</a>
                {% endif %}
            {% endif %}
        </nav>
        <div id="nav-overlay" onclick="toggleNav()">
            <div class="nav-hr-vertical"></div>
            <button id="toggle-nav" class="opened-nav-button-bg"></button>
        </div>
    </div>
    <section class="main">
        <section class="overview" id="overview">
            <h1>Overview</h1>
            <div>
                <div class="field">Job ID</div>
                <div class="text">{{ ctx.job_id }}</div>
            </div>
            <div>
                <div class="field">Generated</div>
                <div class="text">{{ now.strftime("%m/%d/%Y") }}</div>
            </div>
            <div class="generic" id="overview-score">
                {% if ctx.with_synthesizer %}
                    {% include "jinja/components/score_overview.j2" %}
                {% endif %}
            </div>

            {% include "jinja/components/dataset_statistics.j2" %}

        </section>

        
        <section class="synthetic-quality" id="synthetic-quality">
            {% if ctx.with_synthesizer %}
                <h1>Synthetic Quality</h1>
            {% else %}
                <h1>Dataset Quality</h1>
            {% endif %}

            {% if ctx.with_synthesizer %}
            <div class="component" id="synthetic-quality-score">
                <div class="header">
                    Synthetic Quality Score (SQS)
                    <span data-toggle data-for="sqs-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.synthetic_quality_score.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.synthetic_quality_score.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        The Synthetic Data Quality Score is computed by taking a weighted combination of the individual quality metrics: Column Distribution 
                            Stability, Column Correlation Stability, Deep Structure Stability, Text Semantic Similarity and Text Structure Similarity.
                    </div>
                </div>

                <div class="scores-3">

                    {% with name=ctx.column_correlation_stability.name,
                            score=ctx.column_correlation_stability.score.score,
                            grade=ctx.column_correlation_stability.score.grade,
                            figure=ctx.column_correlation_stability.score.figure,
                            anchor_link=ctx.column_correlation_stability.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                    <div class="hr-vertical"></div>

                    {% with name=ctx.deep_structure_stability.name,
                            score=ctx.deep_structure_stability.score.score,
                            grade=ctx.deep_structure_stability.score.grade,
                            figure=ctx.deep_structure_stability.score.figure,
                            anchor_link=ctx.deep_structure_stability.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                    <div class="hr-vertical"></div>

                    {% with name=ctx.column_distribution_stability.name,
                            score=ctx.column_distribution_stability.score.score,
                            grade=ctx.column_distribution_stability.score.grade,
                            figure=ctx.column_distribution_stability.score.figure,
                            anchor_link=ctx.column_distribution_stability.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                </div>
                <div class="scores-2">

                    {% with name=ctx.text_semantic_similarity.name,
                            score=ctx.text_semantic_similarity.score.score,
                            grade=ctx.text_semantic_similarity.score.grade,
                            figure=ctx.text_semantic_similarity.score.figure,
                            anchor_link=ctx.text_semantic_similarity.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                    <div class="hr-vertical"></div>

                    {% with name=ctx.text_structure_similarity.name,
                            score=ctx.text_structure_similarity.score.score,
                            grade=ctx.text_structure_similarity.score.grade,
                            figure=ctx.text_structure_similarity.score.figure,
                            anchor_link=ctx.text_structure_similarity.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                </div>
                <div class="footer">
                    <div class="footer-main">
                        Understand your model's SQS
                        <ul>
                            <li class={{ "warn-option" if ctx.synthetic_quality_score.score.grade in ["Poor", "Moderate" ] }}>Demo environments
                                or mock data</li>
                            <li class={{ "warn-option" if ctx.synthetic_quality_score.score.grade in ["Poor", "Moderate" ] }}>Pre-production
                                testing environments</li>
                            <li class={{ "warn-option" if ctx.synthetic_quality_score.score.grade in ["Poor", "Moderate" , "Good" ] }}>Balance
                                or augment machine learning data source</li>
                            <li class={{ "warn-option" if ctx.synthetic_quality_score.score.grade in ["Poor", "Moderate" , "Good" ] }}>Machine
                                learning or statistical analysis</li>
                        </ul>
                    </div>
                    <div class="tooltips" id="sqs-info" hidden>
                        {{ ctx.tooltips.sqs_info }}
                    </div>
                </div>
            </div>
            {% endif %}

            {% if ctx.get('column_distribution_stability', {}).get('evaluation_fields') %}
                {% include "jinja/components/reference_columns.j2" %}
            {% endif %}

            {% if ctx.get('column_correlation_stability', {}).get('figure') %}
                {% include "jinja/components/correlation.j2" %}
            {% endif %}

            {% if ctx.get('deep_structure_stability', {}).get('figure') %}
                {% include "jinja/components/deep_structure.j2" %}
            {% endif %}

            {% if ctx.with_synthesizer and ctx.get('column_distribution_stability', {}).get('figures') %}
                {% include "jinja/components/column_distribution.j2" %}
            {% endif %}

            {% if ctx.get('text_semantic_similarity', {}).get('figures') %}
                {% include "jinja/components/text_semantic_similarity.j2" %}
            {% endif %}
            
            {% if ctx.get('text_structure_similarity', {}).get('figures') %}
                {% include "jinja/components/text_structure_similarity.j2" %}
            {% endif %}
        </section>

        {% if ctx.with_time_series %}
        <section class="time-series" id="time-series">
            <h1>Time Series Evaluation</h1>

            {% if ctx.get('time_series_similarity_score') %}
            <div class="component" id="ts-score">
                <div class="header">
                    Time Series Similarity Score
                    <span data-toggle data-for="ts-score-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.time_series_similarity_score.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.time_series_similarity_score.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        The Time Series Similarity Score is a weighted composite of individual time series
                        metrics: Drift, Hurst Exponent, DTW, Rolling Stats, and Spectral similarity.
                        It measures how well the synthetic data preserves the temporal characteristics
                        of the original data.
                    </div>
                </div>
                <div class="tooltips" id="ts-score-info" hidden>
                    The score uses an additive weighting method where each metric contributes proportionally
                    to its optimized weight. A score of 1.0 indicates perfect similarity.
                </div>
            </div>
            {% endif %}

            {% if ctx.get('autocorrelation_similarity') %}
                {% with component=ctx.autocorrelation_similarity, tooltip_id="autocorrelation-similarity-info" %}
                    {% include "jinja/components/autocorrelation_similarity.j2" %}
                {% endwith %}
            {% endif %}

            {% if ctx.get('drift_similarity') %}
            <div class="component" id="drift-similarity">
                <div class="header">
                    Drift Similarity
                    <span data-toggle data-for="drift-similarity-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.drift_similarity.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.drift_similarity.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        Measures whether the synthetic data preserves the trend direction and magnitude
                        of the original time series by comparing the mean of first differences.
                    </div>
                </div>
                <div class="tooltips" id="drift-similarity-info" hidden>
                    Drift is computed as the mean of first differences (y[t+1] - y[t]).
                    The error is the normalized absolute difference between original and synthetic drift values.
                </div>
            </div>
            {% endif %}

            {% if ctx.get('hurst_similarity') %}
            <div class="component" id="hurst-similarity">
                <div class="header">
                    Hurst Exponent Similarity
                    <span data-toggle data-for="hurst-similarity-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.hurst_similarity.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.hurst_similarity.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        Compares the long-range memory and trend persistence of the original and synthetic
                        series using the Hurst exponent (H&lt;0.5: mean-reverting, H=0.5: random walk, H&gt;0.5: trending).
                    </div>
                </div>
                <div class="tooltips" id="hurst-similarity-info" hidden>
                    The Hurst exponent is estimated via rescaled range (R/S) analysis on first differences.
                    The similarity is 1 minus the absolute difference between the two exponents.
                </div>
            </div>
            {% endif %}

            {% if ctx.get('dtw_similarity') %}
            <div class="component" id="dtw-similarity">
                <div class="header">
                    DTW Similarity
                    <span data-toggle data-for="dtw-similarity-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.dtw_similarity.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.dtw_similarity.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        Dynamic Time Warping measures overall shape similarity by finding the optimal
                        alignment between the original and synthetic series, allowing flexible time shifts.
                    </div>
                </div>
                <div class="tooltips" id="dtw-similarity-info" hidden>
                    The DTW cost is normalized by series length and scaled by the series' standard
                    deviation to produce a length- and scale-independent similarity score in [0, 1].
                </div>
            </div>
            {% endif %}

            {% if ctx.get('rolling_stats_similarity') %}
            <div class="component" id="rolling-stats-similarity">
                <div class="header">
                    Rolling Statistics Similarity
                    <span data-toggle data-for="rolling-stats-similarity-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.rolling_stats_similarity.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.rolling_stats_similarity.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        Compares how the local average evolves over time by computing the RMSE between
                        the rolling means of the original and synthetic series.
                    </div>
                </div>
                <div class="tooltips" id="rolling-stats-similarity-info" hidden>
                    Rolling mean RMSE is normalized by the series scale to produce a [0, 1] score.
                    Lower RMSE (higher similarity) indicates the synthetic data faithfully reproduces
                    the time-varying mean structure.
                </div>
            </div>
            {% endif %}

            {% if ctx.get('spectral_similarity') %}
            <div class="component" id="spectral-similarity">
                <div class="header">
                    Spectral Similarity
                    <span data-toggle data-for="spectral-similarity-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.spectral_similarity.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.spectral_similarity.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        Measures how well the synthetic data preserves the frequency content of the
                        original series by comparing their power spectral densities.
                    </div>
                </div>
                <div class="tooltips" id="spectral-similarity-info" hidden>
                    The spectral distance is computed as the Jensen-Shannon divergence between the
                    normalized power spectra of the two series, yielding a [0, 1] distance.
                </div>
            </div>
            {% endif %}

            {% if ctx.get('adf_stationarity') %}
            <div class="component" id="adf-stationarity">
                <div class="header">
                    ADF Stationarity Test
                    <span data-toggle data-for="adf-stationarity-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.adf_stationarity.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.adf_stationarity.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="score-description">
                        Checks whether the original and synthetic series share the same stationarity
                        properties using the Augmented Dickey-Fuller test. This is an informational
                        metric not included in the composite score.
                    </div>
                </div>
                <div class="tooltips" id="adf-stationarity-info" hidden>
                    The ADF test determines whether a series has a unit root (non-stationary).
                    A match means both series agree on stationarity status; a mismatch suggests the
                    synthetic data has fundamentally different trend characteristics.
                </div>
            </div>
            {% endif %}

        </section>
        {% endif %}

        {% if (ctx.with_data_privacy) or (ctx.pii_replay and ctx.pii_replay.pii_replay_data) %}
        <section class="data-privacy" id="data-privacy">
            <h1>Data Privacy</h1>
            {% if ctx.with_data_privacy %}
            <div class="component" id="data-privacy-score">
                <div class="header">
                    Data Privacy Score (DPS)
                    <span data-toggle data-for="data-privacy-score-info" class="info"></span>
                </div>
                <div class="score-desc-grid">
                    <div class="score">
                        <div class="score-chart non-hovering">
                            {{ ctx.data_privacy_score.figure }}
                        </div>
                        <span class="score-label">
                            {{ ctx.data_privacy_score.score.grade }}
                        </span>
                    </div>
                    <div class="hr-vertical"></div>
                    <div class="dps-overview">
                        <p class="score-description">                           
                            The Data Privacy Score is determined by the privacy mechanisms you've enabled in the
                            synthetic configuration.
                            The use of these mechanisms helps to ensure that your synthetic data is safe from adversarial
                            attacks.
                        </p>

                        <div class="dps">
                            {% if ctx.dp_enabled %}
                            <div class="dps-btn btn-on">
                                ON
                            </div>
                            {% else %}
                            <div class="dps-btn btn-off">
                                OFF
                            </div>
                            {% endif %}
                            <div class="dps-title">
                                <span>Differential Privacy</span>
                                <span data-toggle="" data-for="differential-privacy-info" class="info"></span>                            
                            </div>
                            {% if ctx.dp_enabled %}
                            <div class="hr-vertical"></div>
                            <span class="dps-value">
                                epsilon: {{ ctx.epsilon }}
                            </span>
                            <span class="dps-value">
                                delta: {{ ctx.delta }}
                            </span>
                            {% endif %}
                        </div>

                    </div>
                </div>
                <div class="tooltips" id="differential-privacy-info" hidden>
                    {{ ctx.tooltips.differential_privacy_info }}
                </div>
                <div class="scores-2">

                    {% with name=ctx.membership_inference_protection.name,
                            score=ctx.membership_inference_protection.score.score,
                            grade=ctx.membership_inference_protection.score.grade,
                            figure=ctx.membership_inference_protection.score.figure,
                            anchor_link=ctx.membership_inference_protection.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                    <div class="hr-vertical"></div>

                    {% with name=ctx.attribute_inference_protection.name,
                            score=ctx.attribute_inference_protection.score.score,
                            grade=ctx.attribute_inference_protection.score.grade,
                            figure=ctx.attribute_inference_protection.score.figure,
                            anchor_link=ctx.attribute_inference_protection.anchor_link %}
                        {% include "jinja/components/score_secondary.j2" %}
                    {% endwith %}

                </div>
                <div class="footer">
                    <div class="footer-main">
                        Understand your model's DPS
                        <ul>
                            <li class={{ "warn-option" if ctx.data_privacy_score.score.grade in ["Poor"] }}>Internally,
                                within the same team</li>
                            <li class={{ "warn-option" if ctx.data_privacy_score.score.grade in ["Poor", "Moderate"] }}>Internally,
                                across different teams</li>
                            <li class={{ "warn-option" if ctx.data_privacy_score.score.grade in ["Poor", "Moderate"
                                , "Good" ] }}>Externally, with trusted partners</li>
                            <li class={{ "warn-option" if ctx.data_privacy_score.score.grade in ["Poor", "Moderate"
                                , "Good" , "Very Good" ] }}>Externally, public availability</li>
                        </ul>
                    </div>
                    <div class="tooltips" id="data-privacy-score-info" hidden>
                        {{ ctx.tooltips.data_privacy_score_info }}
                    </div>
                </div>
            </div>
            {% endif %}

            {% if ctx.pii_replay and ctx.pii_replay.pii_replay_data %}
                {% include "jinja/components/pii_replay.j2" %}
            {% endif %}

            {% if ctx.get('membership_inference_protection', {}).get('figure') %}
                {% include "jinja/components/membership_inference_protection.j2" %}
            {% endif %}

            {% if ctx.get('attribute_inference_protection', {}).get('figure') %}
                {% include "jinja/components/attribute_inference_protection.j2" %}
            {% endif %}

        </section>
        {% endif %}
    </section>
    <script>
        {% include "js/multi_modal_toggle.js" %}
    </script>
</body>

</html>
