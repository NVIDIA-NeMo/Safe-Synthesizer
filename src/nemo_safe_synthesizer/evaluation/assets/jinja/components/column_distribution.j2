<div class="component" id="distribution-stability">
    <div class="header">
        Column Distribution Stability
        <span data-toggle data-for="column-distribution-stability-info" class="info"></span>
    </div>
    <div class="figure-desc">
        <span class="h4">Breakdown of the column distributions</span>
        <br>
        <span><b>Overall Score:</b> {{ ctx.column_distribution_stability.score.score }}</span>
        <br>
        <span><b>Overall Grade:</b> {{ ctx.column_distribution_stability.score.grade }}</span>
    </div>
    {% for figure in ctx.column_distribution_stability.figures %}
        <a id="{{ figure.name1 | urlencode }}"></a>
        {% if figure.name2 %}
            <a id="{{ figure.name2 | urlencode }}"></a>
        {% endif %}
        <figure>
            {{ figure.figure }}
        </figure>
    {% endfor %}
    <div class="footer">
        <div class="tooltips" id="column-distribution-stability-info" hidden>
            {{ ctx.tooltips.column_distribution_stability_info }}
        </div>
    </div>
</div>
