<div class="component" id="semantic-similarity">
    <div class="header">
        Text Semantic Similarity
        <span data-toggle data-for="text-semantic-similarity-info" class="info"></span>
    </div>
    <div class="figure-desc">
        <span class="h4">Breakdown of the semantics of the text columns</span>
        <br>
        <span><b>Overall Score:</b> {{ ctx.text_semantic_similarity.score.score }}</span>
        <br>
        <span><b>Overall Grade:</b> {{ ctx.text_semantic_similarity.score.grade }}</span>
    </div>
    {% for figure in ctx.text_semantic_similarity.figures %}
    <figure>
        {{ figure }}
    </figure>
    {% endfor %}
    <div class="footer">
        <div class="tooltips" id="text-semantic-similarity-info" hidden>
            {{ ctx.tooltips.text_semantic_similarity_info }}
        </div>
    </div>
</div>
