<div class="score">
    <span class="score-label">{{ grade }}</span>
    <a href={{ anchor_link }}>
        <div class="score-chart {{ 'non-hovering' if grade == 'Unavailable' }}">
            {{ figure }}
        </div>
    </a>
    <span class="score-title">{{ name }}</span>
    {% if grade != 'Unavailable' %}
    <a href={{ anchor_link }}><button>View Details</button></a>
    {% endif %}
</div>