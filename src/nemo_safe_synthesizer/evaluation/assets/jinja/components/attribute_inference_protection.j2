<div class="component" id="aia">
    <div class="header">
        Attribute Inference Protection
        <span data-toggle data-for="attribute-inference-info" class="info"></span>
    </div>
    <div class="figure-desc">
        <span class="h4">Breakdown of protection across all columns</span>
        <br>
        <span><b>Overall Score:</b> {{ ctx.attribute_inference_protection.score.score }}</span>
        <br>
        <span><b>Overall Grade:</b> {{ ctx.attribute_inference_protection.score.grade }}</span>
    </div>
    <figure class="figure">
        {{ ctx.attribute_inference_protection.figure }}
    </figure>
    <div class="footer">
        <div class="tooltips" id="attribute-inference-info" hidden>
            {{ ctx.tooltips.attribute_inference_info }}
        </div>
    </div>
</div>
