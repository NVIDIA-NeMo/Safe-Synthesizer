<div class="component" id="mia">
    <div class="header">
        Membership Inference Protection
        <span data-toggle data-for="membership-inference-info" class="info"></span>
    </div>
    <div class="figure-desc">
        <span class="h4">Breakdown of protection level across 360 simulated attacks</span>
        <br>
        <span><b>Overall Score:</b> {{ ctx.membership_inference_protection.score.score }}</span>
        <br>
        <span><b>Overall Grade:</b> {{ ctx.membership_inference_protection.score.grade }}</span>
    </div>
    <figure class="figure">
        {{ ctx.membership_inference_protection.figure }}
    </figure>
    <div class="footer">
        <div class="tooltips" id="membership-inference-info" hidden>
            {{ ctx.tooltips.membership_inference_info }}
        </div>
    </div>
</div>
