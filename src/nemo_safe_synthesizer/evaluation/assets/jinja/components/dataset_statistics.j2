<div class="component" id="dataset-statistics">
    <div class="header">
        Dataset Statistics
        <span data-toggle data-for="dataset-statistics-info" class="info"></span>
    </div>
    <table>
        <tr>
            <th class="first"></th>
            <th class="tnum">
                Reference
            </th>
            <th class="last tnum">
                Output
            </th>
        </tr>
        <tr>
            <td class="first">Row count</td>
            <td class="tnum">{{ ctx.dataset_statistics.reference_rows }}</td>
            <td class="last tnum">{{ ctx.dataset_statistics.output_rows }}</td>
        </tr>
        <tr>
            <td class="first">Column count</td>
            <td class="tnum">{{ ctx.dataset_statistics.reference_cols }}</td>
            <td class="last tnum">{{ ctx.dataset_statistics.output_cols }}</td>
        </tr>
        <tr>
            <td class="first">Missing %</td>
            <td class="tnum">{{ ctx.dataset_statistics.reference_missing }}%</td>
            <td class="last tnum">{{ ctx.dataset_statistics.output_missing }}%</td>
        </tr>
        <tr>
            <td class="first">Reference lines duplicated</td>
            <td class="tnum">N/A</td>
            <td class="last tnum">{{ ctx.dataset_statistics.memorized_lines }}</td>
        </tr>
    </table>
    <div class="footer">
        <div class="footer-main">
            <button data-toggle data-for="dataset-statistics-info">What do these values mean</button>
        </div>
        <div class="tooltips" id="dataset-statistics-info" hidden>
            {{ ctx.tooltips.dataset_statistics_info }}
        </div>
    </div>
</div>
